# Configuración local no secreta. Los secretos se cargan desde Azure Key Vault.
ENVIRONMENT=dev
KEY_VAULT_NAME=kv-licitai-dev

AZURE_STORAGE_CONTAINER_NAME=pliegos-raw
AZURE_SEARCH_ENDPOINT=https://srch-licitai-dev.search.windows.net
AZURE_SEARCH_INDEX_NAME=licitai-pliegos-index

CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
